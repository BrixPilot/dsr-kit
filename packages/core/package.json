{
  "name": "@dsr-kit/core",
  "version": "0.1.0",
  "description": "Auditable GDPR data subject rights for Next.js + Prisma — right-to-erasure, access/export, and tamper-evident proof-of-compliance.",
  "keywords": [
    "gdpr",
    "gdpr-compliance",
    "data-subject-rights",
    "dsr",
    "dsar",
    "right-to-erasure",
    "right-to-be-forgotten",
    "data-deletion",
    "data-erasure",
    "data-export",
    "data-portability",
    "data-privacy",
    "privacy",
    "compliance",
    "audit-trail",
    "proof-of-compliance",
    "prisma",
    "nextjs",
    "postgres",
    "typescript"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "3.2.4"
  }
}
